<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.example.donationapp.controllers.ReceiverController">
    
    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: linear-gradient(to right, #11998e, #38ef7d); -fx-padding: 15;">
            <Label text="🙏 Receiver Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, Receiver" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" 
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5;"/>
        </HBox>
    </top>
    
    <!-- Left Sidebar -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20;" prefWidth="200">
            <Label text="Menu" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Separator/>
            <Button fx:id="applyForCaseBtn" text="📝 Apply for Case" onAction="#showApplyForCase" prefWidth="160"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 10;"/>
            <Button fx:id="myCasesBtn" text="📋 My Cases" onAction="#showMyCases" prefWidth="160"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 10;"/>
            <Button fx:id="viewDonationsBtn" text="💰 Received Donations" onAction="#showReceivedDonations" prefWidth="160"
                    style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 10;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Label fx:id="notificationLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" wrapText="true"/>
        </VBox>
    </left>
    
    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1; -fx-padding: 20;">
            
            <!-- Default Dashboard View -->
            <VBox fx:id="dashboardView" spacing="20" alignment="TOP_CENTER">
                <Label text="Welcome to Your Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                
                <!-- Stats Cards -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" prefWidth="200">
                        <Label fx:id="activeCasesLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                        <Label text="Active Cases" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" prefWidth="200">
                        <Label fx:id="totalReceivedLabel" text="\$0.00" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                        <Label text="Total Received" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" prefWidth="200">
                        <Label fx:id="pendingCasesLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                        <Label text="Pending Approval" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                </HBox>
                
                <!-- My Cases Overview -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                    <Label text="My Cases Overview" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TableView fx:id="overviewCasesTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="caseNameCol" text="Case Name" prefWidth="180"/>
                            <TableColumn fx:id="caseGoalCol" text="Goal Amount" prefWidth="120"/>
                            <TableColumn fx:id="caseRaisedCol" text="Raised" prefWidth="120"/>
                            <TableColumn fx:id="caseStatusCol" text="Status" prefWidth="100"/>
                            <TableColumn fx:id="caseProgressCol" text="Progress" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
            
            <!-- Apply for Case View -->
            <VBox fx:id="applyForCaseView" spacing="15" alignment="TOP_CENTER" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 30;">
                <Label text="Apply for a New Case" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                
                <HBox spacing="30" alignment="CENTER">
                    <VBox spacing="10" prefWidth="400">
                        <Label text="Case Title" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                        <TextField fx:id="caseTitleField" promptText="Enter case title"/>
                        
                        <Label text="Case Description" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                        <TextArea fx:id="caseDescriptionField" promptText="Describe your situation and needs" prefHeight="120"/>
                        
                        <Label text="Goal Amount ($)" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                        <TextField fx:id="goalAmountField" promptText="Enter target amount"/>
                        
                        <Label text="Category" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                        <ComboBox fx:id="categoryComboBox" promptText="Select category" prefWidth="380">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Medical"/>
                                    <String fx:value="Education"/>
                                    <String fx:value="Emergency"/>
                                    <String fx:value="Housing"/>
                                    <String fx:value="Food"/>
                                    <String fx:value="Other"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>
                </HBox>
                
                <Label fx:id="applyMessageLabel" style="-fx-text-fill: red; -fx-font-size: 12px;"/>
                <Button fx:id="submitCaseBtn" text="Submit Application" onAction="#handleSubmitCase"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 30;"/>
                <Button text="Back to Dashboard" onAction="#showDashboard"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </VBox>
            
            <!-- My Cases View -->
            <VBox fx:id="myCasesView" spacing="15" alignment="TOP_CENTER" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 30;">
                <Label text="My Charity Cases" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TableView fx:id="myCasesTable" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="myCaseNameCol" text="Case Name" prefWidth="150"/>
                        <TableColumn fx:id="myCaseDescCol" text="Description" prefWidth="200"/>
                        <TableColumn fx:id="myCaseGoalCol" text="Goal" prefWidth="100"/>
                        <TableColumn fx:id="myCaseRaisedCol" text="Raised" prefWidth="100"/>
                        <TableColumn fx:id="myCaseStatusCol" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="myCaseDateCol" text="Created" prefWidth="100"/>
                    </columns>
                </TableView>
                <Button text="Back to Dashboard" onAction="#showDashboard"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </VBox>
            
            <!-- Received Donations View -->
            <VBox fx:id="receivedDonationsView" spacing="15" alignment="TOP_CENTER" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 30;">
                <Label text="Received Donations" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TableView fx:id="receivedDonationsTable" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="donationDateCol" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="donationDonorCol" text="Donor" prefWidth="150"/>
                        <TableColumn fx:id="donationTypeCol" text="Type" prefWidth="100"/>
                        <TableColumn fx:id="donationAmountCol" text="Amount" prefWidth="100"/>
                        <TableColumn fx:id="donationCaseCol" text="For Case" prefWidth="150"/>
                    </columns>
                </TableView>
                <Button text="Back to Dashboard" onAction="#showDashboard"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </VBox>
            
        </StackPane>
    </center>
    
    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #34495e; -fx-padding: 10;">
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #bdc3c7; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
    
</BorderPane>
